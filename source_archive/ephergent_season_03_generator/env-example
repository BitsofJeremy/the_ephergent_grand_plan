# Ephergent Season 03 Generator - Docker Environment Configuration
# Copy this file to .env and fill in your actual values

# === REQUIRED API KEYS ===
# Get your API key from https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === SECURITY SETTINGS ===
# Generate a secure secret key for production!
# You can generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-production-key-here

# Database password (used by PostgreSQL container)
POSTGRES_PASSWORD=your_secure_postgres_password

# === AUTHENTICATION SETTINGS ===
# Session timeout in hours
SESSION_LIFETIME_HOURS=24

# Set to True in production with HTTPS
SESSION_COOKIE_SECURE=False

# Default admin user (created automatically if no admin users exist)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_PASSWORD=your_secure_admin_password

# === DATABASE CONFIGURATION ===
# Docker Compose uses PostgreSQL by default
# For development, you can override with SQLite:
# DATABASE_URL=sqlite:///stories_dev.db

# Production database URL (for backup scripts and external access)
# Replace with your actual database credentials
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Flask environment (set to production for backup scripts)
FLASK_ENV=production

# === GOOGLE GEMINI SETTINGS ===
# AI model to use
GEMINI_MODEL=gemini-2.5-flash

# === WORKER CONFIGURATION ===
# How often workers check for new stories (seconds)
WORKER_SLEEP_INTERVAL=5

# How long before a worker is considered stale (minutes)
WORKER_TIMEOUT_MINUTES=30

# === STORY GENERATION SETTINGS ===
# Default word count for stories
DEFAULT_WORD_COUNT=500

# Maximum allowed word count
MAX_WORD_COUNT=2000

# Default priority for new stories (higher = more urgent)
DEFAULT_STORY_PRIORITY=0

# Maximum number of stories that can be queued
MAX_QUEUE_SIZE=1000

# === LOGGING CONFIGURATION ===
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# Log file location
LOG_FILE=generator.log

# === DEVELOPMENT/TESTING OVERRIDES ===
# Separate database for development
# DEV_DATABASE_URL=sqlite:///stories_dev.db

# Test API key (if different from main)
# TEST_GEMINI_API_KEY=your_test_api_key_here



# === BLOG & PUBLISHING SETTINGS ===
# Ghost Blog Configuration (optional)
GHOST_ADMIN_KEY=your_ghost_admin_key
GHOST_API_KEY=your_ghost_api_key
GHOST_DOMAIN=yourdomain.com
BLOG_URL=https://yourdomain.com

# YouTube API Configuration (optional)
# Note: client_secret.json and token.json files should be in ./secrets/ directory
YOUTUBE_CATEGORY_ID=24
YOUTUBE_PRIVACY_STATUS=unlisted

# === EXTERNAL SERVICE CONFIGURATION ===
# These are automatically configured for Docker Compose
# Only uncomment and modify if running services externally

# ComfyUI (for image generation)
# COMFYUI_URL=http://localhost:8188  # If running externally
# COMFYUI_URL=http://your-comfyui-server:8188

# Kokoro TTS (for audio generation)
# KOKORO_URL=http://localhost:8880/v1  # If running externally
# KOKORO_URL=http://your-kokoro-server:8880/v1

# === DEVELOPMENT OVERRIDES ===
# Uncomment these for local development outside Docker

# Flask Environment (Docker handles these automatically)
# FLASK_ENV=development
# FLASK_DEBUG=true
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5000
# LOG_LEVEL=DEBUG



