        },
        {
            "segment_id": "seg_003",
            "page_number": 12,
            "section": "great_pillar",
            "speaker": "pixel",
            "speaker_mode": "dialogue",
            "text": "Are you certain?",
            "direction": "Pixel asking Arc one final time",
            "audio_cues": {
                "tone": "final question, protective concern",
                "pacing": "measured, heavy",
                "emphasis_words": [
                    "certain"
                ]
            },
