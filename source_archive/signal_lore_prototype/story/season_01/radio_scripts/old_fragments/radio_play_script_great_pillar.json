        {
            "segment_id": "seg_002",
            "page_number": 12,
            "section": "great_pillar",
            "speaker": "pixel",
            "speaker_mode": "narration",
            "text": "Arc floated before it, his projection larger than I'd ever seen—ten feet of geometric shapes cycling through configurations that hurt to watch directly. The stabilizer device from the Quiet hummed in my hands, calibrated and ready.",
            "direction": null,
            "audio_cues": {
                "tone": "observing Arc's magnitude, readiness",
