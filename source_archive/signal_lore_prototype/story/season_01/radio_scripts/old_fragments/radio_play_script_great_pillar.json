            "page_number": 12,
            "section": "great_pillar",
            "speaker": "pixel",
            "speaker_mode": "narration",
            "text": "His wristband form detached from my arm, hovering independently. Mochi pressed against my chest, glowing that steady white that meant pay attention. Clive stood at my shoulder, symbols blazing bright enough to cast shadows.",
            "direction": null,
