            "segment_id": "seg_010",
            "page_number": 12,
            "section": "great_pillar",
            "speaker": "pixel",
            "speaker_mode": "narration",
            "text": "The Builders. Not gone. Sleeping. Dreaming themselves into the fabric of the Signal, waiting for someone to understand the transition they'd started and couldn't finish.",
            "direction": null,
            "audio_cues": {
                "tone": "understanding the Builders' state",
                "pacing": "measured, reverent",
                "emphasis_words": [
