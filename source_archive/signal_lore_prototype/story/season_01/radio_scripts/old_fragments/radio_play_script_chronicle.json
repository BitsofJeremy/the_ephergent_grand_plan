    {
      "segment_id": "seg_231",
      "page_number": 22,
      "section": "chronicle_entry",
      "speaker": "pixel",
      "speaker_mode": "internal_monologue",
      "text": "Someone has to find it. Someone has to write it down before it's too late.",
      "direction": "Expressing urgency",
      "audio_cues": {
        "tone": "urgent determination",
        "pacing": "quick, driven",
        "emphasis_words": [
