    {
      "segment_id": "seg_237",
      "page_number": 23,
      "section": "chronicle_entry",
      "speaker": "pixel",
      "speaker_mode": "internal_monologue",
      "text": "The Quiet said we accelerated the end. I don't know if that's true. But I do know this: we're not stopping. Whatever we started today in Memorywreck Bay, we're seeing it through.",
      "direction": "Statement of resolution",
      "audio_cues": {
