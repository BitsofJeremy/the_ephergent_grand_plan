    {
      "segment_id": "seg_236",
      "page_number": 23,
      "section": "chronicle_entry",
      "speaker": "pixel",
      "speaker_mode": "internal_monologue",
      "text": "Mochi hasn't stopped glowing violet since we left the Garden. Arc's been running self-diagnostics on loop. Clive's been standing at the window, watching the horizon, not speaking. Even through the Signal, I can feel his silence. It's not peaceful. It's the silence of someone waiting for something they don't want to arrive.",
      "direction": "Observation of immediate aftermath",
      "audio_cues": {
        "tone": "worried observation",
        "pacing": "steady, concerned",
        "emphasis_words": [
          "violet",
          "self-diagnostics",
          "standing at the window",
          "waiting",
          "don't want to arrive"
        ]
      },
      "timing": {
