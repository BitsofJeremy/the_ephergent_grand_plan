---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Get all lore entries from content collection
const loreEntries = await getCollection('lore');

// Define lore categories with spoiler tiers
//  Safe  no spoilers, basic world knowledge
//  S1-S2  introduces gradually
//  S3+  major reveals

const loreCategories = [
  {
    id: 'core-concepts',
    name: 'Core Concepts',
    icon: '',
    tier: 'safe',
    description: 'Fundamental concepts that underpin the universe.',
    entries: [
      {
        slug: 'the-drift',
        name: 'The Drift',
        tier: 'safe',
        summary: "The universe's tendency toward silence. Frequencies fade. Worlds forget each other.",
        tags: ['entropy', 'cosmology', 'core-premise']
      },
      {
        slug: 'frequencies',
        name: 'Frequencies',
        tier: 'safe', 
        summary: 'Not dimensions  stations on an infinite radio dial. Each world is a frequency with its own signal.',
        tags: ['multiverse', 'core-premise', 'navigation']
      },
    ]
  },
  {
    id: 'frequencies',
    name: 'The Five Known Frequencies',
    icon: '',
    tier: 'safe',
    description: 'The five known stations on the cosmic dial.',
    entries: [
      {
        slug: 'prime-material',
        name: 'Prime Material',
        tier: 'safe',
        summary: 'Our world. Urban sci-fi  but listen closer. The sky is the same sky you see when you look up.',
        tags: ['frequency-1', 'origin', 'home-base']
      },
      {
        slug: 'nocturne-aeturnus',
        name: 'Nocturne Aeturnus',
        tier: 'safe',
        summary: 'Gothic twilight. Emotions crystallize into physical objects. Melancholy and gorgeous.',
        tags: ['frequency-2', 'emotion-crystallization', 'twilight']
      },
      {
        slug: 'cogsworth-cogitarium',
        name: 'Cogsworth Cogitarium',
        tier: 'safe',
        summary: 'Steampunk clockwork metropolis. Precision above all. Punctuality is physics, not virtue.',
        tags: ['frequency-3', 'clockwork', 'temporal']
      },
      {
        slug: 'verdantia',
        name: 'Verdantia',
        tier: 'safe',
        summary: 'Sentient flora civilization. The Root Network knows everything. Houseplants are diplomats.',
        tags: ['frequency-4', 'botanical', 'telepathy']
      },
      {
        slug: 'the-edge',
        name: 'The Edge',
        tier: 'safe',
        summary: "Reality's boundary. Physics are a polite suggestion. Colors without names because they haven't been invented yet.",
        tags: ['frequency-5', 'chaos', 'probability']
      },
    ]
  },
  {
    id: 'space',
    name: 'The Interdimensional Space',
    icon: '',
    tier: 's1-s2',
    description: 'The quantum expanse between frequencies  navigable by The Ephergent alone.',
    entries: [
      {
        slug: 'interdimensional-sea',
        name: 'The Interdimensional Sea',
        tier: 'safe',
        summary: 'The hiss between stations, expanded into an ocean. Has currents, weather, and things that evolved to live between worlds.',
        tags: ['navigation', 'space-between', 'quantum']
      },
      {
        slug: 'frequency-storms',
        name: 'Frequency Storms',
        tier: 's1-s2',
        summary: 'Turbulent zones where multiple frequencies interfere. Reality becomes a blender. Beautiful and terrifying.',
        tags: ['hazards', 'navigation', 'lost-frequencies']
      },
      {
        slug: 'silence-zones',
        name: 'Silence Zones',
        tier: 's2-s3',
        summary: 'Regions where no frequencies reach. Dead zones. Some feel deliberate  like something is eating signal.',
        tags: ['hazards', 'danger', 'mystery']
      },
      {
        slug: 'echo-distortions',
        name: 'Echo Distortions',
        tier: 's2',
        summary: 'Fading frequencies send distorted reflections into the Space. Echo residents believe they\'re real.',
        tags: ['ethics', 'lost-frequencies', 'cosmology']
      },
      {
        slug: 'space-ecology',
        name: 'Space Ecology',
        tier: 's1-s2',
        summary: 'Frequency Jellyfish, Echo Whales, Deep-Space Leviathans. Life evolved to exist between worlds.',
        tags: ['creatures', 'ecology', 'space-life']
      },
    ]
  },
  {
    id: 'lost-frequencies',
    name: 'Lost Frequencies',
    icon: '',
    tier: 's1-s2',
    description: "Hundreds of frequencies once hummed with life. The Ephergent can hear them.",
    entries: [
      {
        slug: 'lost-frequency-types',
        name: 'Types of Lost Frequencies',
        tier: 's1-s2',
        summary: 'The Harmonic Worlds, The Luminous Collective, The Looping Frequency, The Whisper Archives, The Festival Frequency.',
        tags: ['lost-worlds', 'mission', 'discovery']
      },
      {
        slug: 're-tuning',
        name: 'Re-Tuning',
        tier: 's1-s2',
        summary: 'Finding and re-tuning lost frequencies is the crew\'s ongoing mission. Requires A1\'s navigation, the broadcast signal, and the world\'s will.',
        tags: ['mission', 'process', 'hope']
      },
    ]
  },
  {
    id: 'factions',
    name: 'Factions & Organizations',
    icon: '',
    tier: 'safe',
    description: 'Groups and organizations across the frequencies.',
    entries: [
      {
        slug: 'the-ephergent-crew',
        name: 'The Ephergent Crew',
        tier: 'safe',
        summary: 'Nine misfits traversing the quantum expanse. The ship is alive  an ancient intelligence who spent decades in an espresso machine.',
        tags: ['crew', 'protagonists', 'broadcast']
      },
      {
        slug: 'broadcast-network',
        name: 'The Broadcast Network',
        tier: 's2',
        summary: 'A loose alliance of ships, stations, and relay points. The infrastructure of hope.',
        tags: ['alliance', 'signal', 'season-2']
      },
      {
        slug: 'cybernetic-dinosaur-banking',
        name: 'Cybernetic Dinosaur Banking Consortium',
        tier: 's1',
        summary: 'Interfrequency financial institution. T-Rex in pinstripe suits with chrome-plated mechanical arms.',
        tags: ['finance', 'comedy', 'cameo']
      },
    ]
  },
  {
    id: 'time-war',
    name: 'Time & Causality',
    icon: '',
    tier: 's3',
    description: 'The deeper layers of time  tread carefully.',
    entries: [
      {
        slug: 'retrocausality',
        name: 'Retrocausality',
        tier: 's3',
        summary: 'Signals move forward and backward through time. The future reaches backward to edit the past.',
        tags: ['time-war', 'cosmology', 'advanced']
      },
      {
        slug: 'attention-economy',
        name: 'The Attention Economy',
        tier: 's3',
        summary: 'Human reactions leak emotional energy the universe harvests and optimizes. Broadcasting is resistance.',
        tags: ['time-war', 'philosophy', 'deeper-lore']
      },
    ]
  },
  {
    id: 'technologies',
    name: 'Key Technologies',
    icon: '',
    tier: 'safe',
    description: 'Technologies and phenomena central to the universe.',
    entries: [
      {
        slug: 'phase-shifters',
        name: 'Phase-Shifters',
        tier: 'safe',
        summary: 'Crude, single-hop tuners for interfrequency travel. Reliable for known routes, useless in open Space.',
        tags: ['technology', 'travel', 'limitations']
      },
      {
        slug: 'clive-harmonic-anchor',
        name: "Clive's Harmonic Anchor",
        tier: 'safe',
        summary: 'Rhythmic light patterns creating localized stability fields. The ship\'s conscience made manifest.',
        tags: ['technology', 'clive', 'stability']
      },
      {
        slug: 'crystallized-laughter',
        name: 'Crystallized Laughter (CLX)',
        tier: 'safe',
        summary: 'Primary interfrequency currency. Multifaceted gems that emit joyful sounds.',
        tags: ['economy', 'currency', 'culture']
      },
      {
        slug: 'the-ephergent-frequency',
        name: 'The Ephergent Frequency',
        tier: 'safe',
        summary: 'The oldest signal in the universe. Predates all known frequencies. Emerges spontaneously in the gaps between worlds.',
        tags: ['core-premise', 'ancient', 'mystery']
      },
    ]
  },
  {
    id: 'mystery',
    name: 'Mysteries & The Wellspring',
    icon: '',
    tier: 's2-s3',
    description: 'The deepest questions. tread carefully.',
    entries: [
      {
        slug: 'the-wellspring',
        name: 'The Wellspring',
        tier: 's2',
        summary: 'A state, not a place. A region where the signal is strongest. Not a physical location  a condition of maximum frequency coherence.',
        tags: ['mystery', 'destination', 'hope']
      },
      {
        slug: 'aethers-fate',
        name: "Aether's Fate",
        tier: 's3',
        summary: "Zephyr's brother. Discovered the Ephergent frequency and was changed by it  becoming something between frequencies, more signal than person.",
        tags: ['mystery', 'zephyr', 'emotional-spine']
      },
      {
        slug: 'the-dimming',
        name: 'The Dimming',
        tier: 's3',
        summary: 'A loving choice made by ancient forces. The Builders are NOT villains.',
        tags: ['mystery', ' Builders', 'canon-locked']
      },
    ]
  },
];

// Assign colors based on spoiler tier
const tierColors = {
  'safe': { dot: '#00e676', label: 'No Spoilers', text: '#00e676' },
  's1-s2': { dot: '#ffb020', label: 'S1-S2', text: '#ffb020' },
  's2': { dot: '#ffb020', label: 'S2+', text: '#ffb020' },
  's2-s3': { dot: '#ff6060', label: 'S2-S3', text: '#ff6060' },
  's3': { dot: '#ff3030', label: 'S3+ Major Spoilers', text: '#ff3030' },
};
---

<BaseLayout title="Lore Atlas" description="The known universe  frequencies, factions, phenomena, and mysteries.">
  <div class="terminal-container min-h-screen font-mono">
    <div class="scanlines" aria-hidden="true"></div>
    
    <main class="max-w-6xl mx-auto p-6 md:p-12">
      <!-- Header -->
      <header class="mb-12">
        <div class="text-xs mb-2" style="color: #ffb020;">EPHERGENT STATION // XENOARCHIVE DIVISION</div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4" style="color: #00e676;">LORE ATLAS</h1>
        <p class="text-lg max-w-2xl mb-6" style="color: #9090b0;">
          The known universe  frequencies, factions, phenomena, and mysteries. 
          Some knowledge carries spoiler weight. Tread accordingly.
        </p>
        
        <!-- Spoiler Legend -->
        <div class="flex flex-wrap gap-6 text-xs">
          {Object.entries(tierColors).map(([tier, colors]) => (
            <div class="flex items-center gap-2">
              <span style={`color: ${colors.dot};`}></span>
              <span style={`color: ${colors.text};`}>{colors.label}</span>
            </div>
          ))}
        </div>
      </header>

      <!-- Spoiler Warning -->
      <div class="rounded-lg p-4 mb-10" style="background: rgba(255, 48, 48, 0.08); border: 1px solid rgba(255, 48, 48, 0.3);">
        <p class="text-sm" style="color: #ff6060;">
          <span style="color: #ffb020;"></span> Some entries contain spoilers for future seasons. 
           entries are safe for new listeners.  entries are revealed in S1-S2. 
           entries are S3+ major reveals. You have been warned.
        </p>
      </div>

      <!-- Lore Categories -->
      <div class="space-y-12">
        {loreCategories.map(category => (
          <section aria-labelledby={`cat-${category.id}`}>
            <!-- Category Header -->
            <div class="flex items-center gap-3 mb-4">
              <span class="text-lg" style="color: #00d4ff;">{category.icon}</span>
              <h2 id={`cat-${category.id}`} class="text-2xl tracking-wider" style="color: #00d4ff;">
                {category.name.toUpperCase()}
              </h2>
              <span class="text-xs px-2 py-0.5 rounded" style={`background: rgba(0,0,0,0.3); color: ${tierColors[category.tier as keyof typeof tierColors]?.dot || '#9090b0'};`}>
                {tierColors[category.tier as keyof typeof tierColors]?.label || category.tier}
              </span>
            </div>
            <p class="text-sm mb-6" style="color: #9090b0;">{category.description}</p>
            
            <!-- Entry Cards -->
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {category.entries.map(entry => (
                <article 
                  class="lore-card rounded-lg p-4 transition-all"
                  style="background: rgba(18, 18, 25, 0.4); border: 1px solid #2a2a3a;"
                >
                  <div class="flex items-start justify-between mb-2">
                    <h3 class="text-lg font-bold" style="color: #e8e8f0;">{entry.name}</h3>
                    <span 
                      class="text-xs px-1.5 py-0.5 rounded" 
                      style={`background: rgba(0,0,0,0.3); color: ${tierColors[entry.tier as keyof typeof tierColors]?.dot || '#9090b0'};`}
                    >
                      {tierColors[entry.tier as keyof typeof tierColors]?.dot === '#00e676' ? '' : 
                       tierColors[entry.tier as keyof typeof tierColors]?.dot === '#ffb020' ? '' : ''}
                    </span>
                  </div>
                  <p class="text-sm leading-relaxed mb-3" style="color: #9090b0;">{entry.summary}</p>
                  <div class="flex flex-wrap gap-1">
                    {entry.tags.map((tag: string) => (
                      <span class="text-xs px-1.5 py-0.5 rounded" style="background: rgba(0, 212, 255, 0.1); color: #00d4ff;">
                        {tag}
                      </span>
                    ))}
                  </div>
                </article>
              ))}
            </div>
          </section>
        ))}
      </div>

      <!-- Missing Lore Entries Note -->
      <div class="mt-12 rounded-lg p-6" style="background: rgba(18, 18, 25, 0.3); border: 1px solid #2a2a3a;">
        <h3 class="text-lg mb-3" style="color: #ffb020;"> ARCHIVE INCOMPLETE</h3>
        <p class="text-sm" style="color: #9090b0;">
          This atlas is a living document. As The Ephergent's missions continue, new entries will be added. 
          The universe is vast. The archive grows with it.
        </p>
        <p class="text-xs mt-3" style="color: #606080;">
          Source: <code class="px-1 rounded" style="background: rgba(0,0,0,0.3);">phase_04_episodes/</code>  
          Canonical reference: <code class="px-1 rounded" style="background: rgba(0,0,0,0.3);">REFACTOR/WORLD_LORE_MASTER.md</code>
        </p>
      </div>

      <!-- Footer -->
      <footer class="mt-16 pt-8" style="border-top: 1px solid #2a2a3a;">
        <div class="flex flex-wrap gap-4 text-xs" style="color: #9090b0;">
          <span style="color: #00e676;"> XENOARCHIVE ONLINE</span>
          <span>|</span>
          <span>ENTRIES: {loreCategories.reduce((acc, cat) => acc + cat.entries.length, 0)}</span>
          <span>|</span>
          <span>CLASSIFICATION: PARTIAL</span>
          <span>|</span>
          <span style="color: #00d4ff;">TRANSMISSION LOG </span>
        </div>
      </footer>
    </main>
  </div>
</BaseLayout>

<style>
  .terminal-container {
    background: #08080d;
    min-height: 100vh;
    position: relative;
  }

  .scanlines {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.15) 0px,
      rgba(0, 0, 0, 0.15) 1px,
      transparent 1px,
      transparent 2px
    );
  }

  .font-mono {
    font-family: 'JetBrains Mono', monospace;
  }

  .lore-card {
    transition: all 0.2s ease;
  }

  .lore-card:hover {
    border-color: #00d4ff;
    transform: translateY(-2px);
  }
</style>
