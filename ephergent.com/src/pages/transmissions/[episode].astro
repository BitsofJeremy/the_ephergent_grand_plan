---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';

// Generate static paths for all episodes
export async function getStaticPaths() {
  const episodesBase = '/home/debian/Documents/code_repos/the_ephergent_grand_plan/phase_04_episodes';
  const paths = [] as Array<{params: {episode: string}, props: any}>;

  try {
    const seasonDirs = await readdir(episodesBase);
    
    for (const seasonDir of seasonDirs) {
      if (!seasonDir.startsWith('season')) continue;
      
      const seasonPath = join(episodesBase, seasonDir);
      const files = await readdir(seasonPath);
      
      for (const file of files) {
        if (!file.endsWith('.md')) continue;
        
        const match = file.match(/S(\d+)E(\d+)_(.+)\.md$/);
        if (!match) continue;
        
        const slugName = file.replace('.md', '');
        
        paths.push({
          params: { episode: slugName },
          props: { 
            season: match[1],
            episode: match[2],
          }
        });
      }
    }
  } catch (e) {
    console.error('Error generating paths:', e);
  }

  return paths;
}

const { episode: episodeSlug } = Astro.params;

// Read episode file
const episodesBase = '/home/debian/Documents/code_repos/the_ephergent_grand_plan/phase_04_episodes';

let frontmatter: any = null;
let content = '';
let error = false;

try {
  // Search for the file
  const seasonDirs = await readdir(episodesBase);
  
  for (const seasonDir of seasonDirs) {
    if (!seasonDir.startsWith('season')) continue;
    
    const seasonPath = join(episodesBase, seasonDir);
    const files = await readdir(seasonPath);
    
    const targetFile = files.find(f => f.replace('.md', '') === episodeSlug);
    
    if (targetFile) {
      const filePath = join(seasonPath, targetFile);
      const raw = await readFile(filePath, 'utf-8');
      
      // Parse frontmatter
      const fmMatch = raw.match(/^---\n([\s\S]*?)\n---/);
      if (fmMatch) {
        const fmLines = fmMatch[1].split('\n');
        frontmatter = {};
        for (const line of fmLines) {
          const colonIdx = line.indexOf(':');
          if (colonIdx === -1) continue;
          const key = line.slice(0, colonIdx).trim();
          let value = line.slice(colonIdx + 1).trim();
          // Remove quotes
          value = value.replace(/^["']|["']$/g, '');
          
          if (key === 'featured_characters') {
            // Parse array
            frontmatter[key] = value.replace(/[\[\]]/g, '').split(',').map((s: string) => s.trim());
          } else {
            frontmatter[key] = value;
          }
        }
      }
      
      // Get content after frontmatter
      content = raw.replace(/^---[\s\S]*?---\n/, '');
      break;
    }
  }
  
  if (!frontmatter) {
    error = true;
  }
} catch (e) {
  console.error('Error reading episode:', e);
  error = true;
}
---

<BaseLayout 
  title={frontmatter?.title ? `${frontmatter.title} | Ephergent` : 'Transmission Not Found'} 
  description={frontmatter?.summary || `Season ${frontmatter?.season || '?'}, Episode ${frontmatter?.episode || '?'}`}
>
  <div class="terminal-container min-h-screen font-mono">
    <div class="scanlines" aria-hidden="true"></div>
    
    <main class="max-w-4xl mx-auto p-6 md:p-12">
      {error || !frontmatter ? (
        <!-- Error state -->
        <div class="text-center py-16">
          <div class="text-4xl mb-4" style="color: #ffb020;"></div>
          <h1 class="text-2xl mb-2" style="color: #e8e8f0;">TRANSMISSION NOT FOUND</h1>
          <p class="mb-8" style="color: #9090b0;">The requested broadcast could not be located in the archive.</p>
          <a href="/transmissions/" style="color: #00d4ff;">
             Return to Transmission Archive
          </a>
        </div>
      ) : (
        <>
          <!-- Episode Header -->
          <header class="mb-8">
            <a href="/transmissions/" class="text-sm mb-4 inline-block transition-colors" style="color: #9090b0;">
               ARCHIVE
            </a>
            
            <div class="rounded-lg p-6" style="background: rgba(18, 18, 25, 0.4); border: 1px solid #2a2a3a;">
              <!-- Meta -->
              <div class="flex flex-wrap items-center gap-4 mb-4">
                <span class="font-bold text-xl" style="color: #00e676;">S{frontmatter.season}E{frontmatter.episode}</span>
                <span style="color: #9090b0;">|</span>
                {frontmatter.stardate && (
                  <>
                    <span class="text-sm" style="color: #ffb020;">{frontmatter.stardate}</span>
                    <span style="color: #9090b0;">|</span>
                  </>
                )}
                <span class="text-sm" style="color: #9090b0;">
                  Narrated by <span style="color: #00d4ff;">{frontmatter.narrator}</span>
                </span>
              </div>
              
              <!-- Title -->
              <h1 class="text-3xl md:text-4xl font-bold mb-4 tracking-tight" style="color: #e8e8f0;">
                {frontmatter.title}
              </h1>
              
              <!-- Summary -->
              {frontmatter.summary && (
                <p class="leading-relaxed text-lg" style="color: #9090b0;">
                  {frontmatter.summary}
                </p>
              )}
              
              <!-- Featured Characters -->
              {frontmatter.featured_characters && frontmatter.featured_characters.length > 0 && (
                <div class="mt-4 pt-4" style="border-top: 1px solid #2a2a3a;">
                  <span class="text-xs" style="color: #9090b0;">FEATURED: </span>
                  {frontmatter.featured_characters.map((char: string, i: number) => (
                    <span class="text-sm" style="color: #ffb020;">
                      {char}{i < frontmatter.featured_characters.length - 1 ? ', ' : ''}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </header>

          <!-- Episode Content -->
          <article class="transmission-content">
            <!-- Simple markdown-like rendering -->
            <div set:html={content
              .replace(/^## (.+)$/gm, '<h2 class="text-xl mt-8 mb-4" style="color: #00d4ff; font-family: JetBrains Mono, monospace;">$1</h2>')
              .replace(/^### (.+)$/gm, '<h3 class="text-lg mt-6 mb-3" style="color: #ffb020;">$1</h3>')
              .replace(/\*\*(.+?)\*\*/g, '<strong style="color: #e8e8f0;">$1</strong>')
              .replace(/\*(.+?)\*/g, '<em>$1</em>')
              .replace(/^> (.+)$/gm, '<blockquote class="border-l-2 pl-4 my-4 italic" style="border-color: rgba(0, 212, 255, 0.5); color: #9090b0;">$1</blockquote>')
              .replace(/^---$/gm, '<hr class="my-8" style="border-color: #2a2a3a;" />')
              .replace(/\n\n/g, '</p><p class="leading-relaxed mb-4" style="color: #9090b0; font-family: Inter, sans-serif;">')
              .replace(/^(?!<[hHbBpPlL]|<blockquote|<hr)(.+)$/gm, '<p class="leading-relaxed mb-4" style="color: #9090b0; font-family: Inter, sans-serif;">$1</p>')
            } />
          </article>

          <!-- Audio indicator -->
          <div class="mt-12 p-4 rounded-lg" style="background: rgba(255, 176, 32, 0.05); border: 1px solid rgba(255, 176, 32, 0.3);">
            <div class="flex items-center gap-3">
              <span style="color: #ffb020;"></span>
              <span class="text-sm" style="color: #9090b0;">Audio transmission available</span>
              <span class="text-xs" style="color: #9090b0;">|</span>
              <a href={`/audio/season0${frontmatter.season}/S${frontmatter.season}E${frontmatter.episode}.mp3`} class="text-sm transition-colors" style="color: #00d4ff;">
                 Listen to broadcast
              </a>
            </div>
          </div>

          <!-- Navigation -->
          <footer class="mt-12 pt-8" style="border-top: 1px solid #2a2a3a;">
            <a href="/transmissions/" class="transition-colors" style="color: #9090b0;">
               Return to Transmission Archive
            </a>
          </footer>
        </>
      )}
    </main>
  </div>
</BaseLayout>

<style>
  .terminal-container {
    background: #08080d;
    min-height: 100vh;
    position: relative;
  }

  .scanlines {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.15) 0px,
      rgba(0, 0, 0, 0.15) 1px,
      transparent 1px,
      transparent 2px
    );
  }

  .font-mono {
    font-family: 'JetBrains Mono', monospace;
  }
</style>
