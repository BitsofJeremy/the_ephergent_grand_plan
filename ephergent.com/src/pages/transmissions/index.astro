---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { readdir, readFile } from 'fs/promises';
import { join } from 'path';

// Get episodes from phase_04_episodes directory structure
const episodesBase = '/home/debian/Documents/code_repos/the_ephergent_grand_plan/phase_04_episodes';

interface Episode {
  season: string;
  episode: string;
  title: string;
  slug: string;
  stardate: string;
  summary: string;
  narrator: string;
}

// Scan for all episode files
async function getEpisodes(): Promise<Episode[]> {
  const episodes: Episode[] = [];
  
  try {
    const seasonDirs = await readdir(episodesBase);
    
    for (const seasonDir of seasonDirs) {
      if (!seasonDir.startsWith('season')) continue;
      const season = seasonDir.replace('season0', '');
      
      try {
        const seasonPath = join(episodesBase, seasonDir);
        const files = await readdir(seasonPath);
        
        for (const file of files) {
          if (!file.endsWith('.md')) continue;
          
          const match = file.match(/S(\d+)E(\d+)_(.+)\.md$/);
          if (!match) continue;
          
          const episodeNum = match[2];
          const slugName = file.replace('.md', '');
          
          const filePath = join(seasonPath, file);
          const content = await readFile(filePath, 'utf-8');
          
          // Parse frontmatter
          const fmMatch = content.match(/^---\n([\s\S]*?)\n---/);
          let frontmatter: Record<string, any> = {};
          
          if (fmMatch) {
            const fmLines = fmMatch[1].split('\n');
            for (const line of fmLines) {
              const colonIdx = line.indexOf(':');
              if (colonIdx === -1) continue;
              const key = line.slice(0, colonIdx).trim();
              let value = line.slice(colonIdx + 1).trim();
              // Remove quotes
              value = value.replace(/^["']|["']$/g, '');
              frontmatter[key] = value;
            }
          }
          
          episodes.push({
            season: season,
            episode: episodeNum,
            title: frontmatter.title || `Episode ${episodeNum}`,
            slug: slugName,
            stardate: frontmatter.stardate || `Cycle ${season}.${episodeNum.padStart(3, '0')}`,
            summary: frontmatter.summary || '',
            narrator: frontmatter.narrator || 'unknown',
          });
        }
      } catch (e) {
        console.error(`Error reading season ${seasonDir}:`, e);
      }
    }
  } catch (e) {
    console.error('Error reading episodes directory:', e);
  }
  
  // Sort by season and episode
  episodes.sort((a, b) => {
    if (a.season !== b.season) return a.season.localeCompare(b.season);
    return a.episode.localeCompare(b.episode);
  });

  // Restrict to visible episodes only — full arc stays hidden
  const VISIBLE_EPISODES = ['S01E01_the_day_the_dial_broke'];
  return episodes.filter(ep => VISIBLE_EPISODES.includes(ep.slug));
}

const episodes = await getEpisodes();

// Group by season
const seasons = episodes.reduce((acc, ep) => {
  if (!acc[ep.season]) acc[ep.season] = [];
  acc[ep.season].push(ep);
  return acc;
}, {} as Record<string, Episode[]>);

// Latest episode for header
const latestEp = episodes[episodes.length - 1];
---

<BaseLayout title="Transmissions" description="Episode archive  The Ephergent broadcast log.">
  <div class="terminal-container min-h-screen font-mono">
    <div class="scanlines" aria-hidden="true"></div>
    
    <main class="max-w-6xl mx-auto p-6 md:p-12">
      <!-- Header -->
      <header class="mb-12">
        <div class="text-xs mb-2" style="color: #ffb020;">EPHERGENT STATION // TRANSMISSION ARCHIVE</div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4" style="color: #00e676;">TRANSMISSION LOG</h1>
        <p class="text-lg max-w-2xl" style="color: #9090b0;">
          Archived broadcasts from the crew of The Ephergent. 
          {episodes.length > 0 ? `Current log contains ${episodes.length} transmissions across ${Object.keys(seasons).length} seasons.` : 'No transmissions logged.'}
        </p>
      </header>

      {latestEp && (
        <div class="rounded-lg p-4 mb-12" style="background: rgba(255, 176, 32, 0.05); border: 1px solid rgba(255, 176, 32, 0.3);">
          <div class="text-xs mb-2" style="color: #ffb020;"> LATEST TRANSMISSION</div>
          <div class="flex items-center gap-4">
            <span class="font-bold text-lg" style="color: #00e676;">S{latestEp.season}E{latestEp.episode}</span>
            <span style="color: #9090b0;">|</span>
            <span class="text-sm" style="color: #ffb020;">{latestEp.stardate}</span>
          </div>
          <a href={`/transmissions/${latestEp.slug}/`} class="text-xl mt-2 inline-block" style="color: #e8e8f0;">
            {latestEp.title}
          </a>
        </div>
      )}

      <!-- Season Archives -->
      {Object.entries(seasons).sort(([a], [b]) => a.localeCompare(b)).map(([season, eps]) => (
        <section class="season-archive mb-12" aria-label={`Season ${season}`}>
          <div class="flex items-center gap-4 mb-6">
            <h2 class="text-2xl tracking-wider" style="color: #00d4ff;">SEASON {season}</h2>
            <div class="flex-1 h-px" style="background: #2a2a3a;"></div>
            <span class="text-sm" style="color: #9090b0;">{eps.length} transmissions</span>
          </div>
          
          <div class="grid gap-3">
            {eps.map(ep => (
              <article class="rounded-lg p-4 transition-all" style="background: rgba(18, 18, 25, 0.3); border: 1px solid #2a2a3a;">
                <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
                  <div class="flex items-center gap-3">
                    <span class="font-bold" style="color: #00e676;">S{ep.season}E{ep.episode}</span>
                    <span class="text-sm" style="color: #ffb020;">{ep.stardate}</span>
                  </div>
                  <div class="flex-1 min-w-[200px]">
                    <a href={`/transmissions/${ep.slug}/`} class="text-lg" style="color: #e8e8f0;">
                      {ep.title}
                    </a>
                  </div>
                  <div class="flex items-center gap-3">
                    <span class="text-xs" style="color: #9090b0;">narrated by {ep.narrator}</span>
                    <a href={`/transmissions/${ep.slug}/`} class="text-sm transition-colors" style="color: #00d4ff;">
                      [ACCESS] 
                    </a>
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      ))}

      {episodes.length === 0 && (
        <div class="text-center py-16">
          <div class="text-4xl mb-4" style="color: #ffb020;"></div>
          <h3 class="text-xl mb-2" style="color: #e8e8f0;">NO TRANSMISSIONS LOGGED</h3>
          <p style="color: #9090b0;">The archive is empty. New broadcasts will appear here when available.</p>
        </div>
      )}

      <!-- Footer -->
      <footer class="mt-16 pt-8" style="border-top: 1px solid #2a2a3a;">
        <div class="flex flex-wrap gap-4 text-xs" style="color: #9090b0;">
          <span style="color: #00e676;"> ARCHIVE ONLINE</span>
          <span>|</span>
          <span>TOTAL TRANSMISSIONS: {episodes.length}</span>
          <span>|</span>
          <span>STORAGE: NOMINAL</span>
        </div>
      </footer>
    </main>
  </div>
</BaseLayout>

<style>
  .terminal-container {
    background: #08080d;
    min-height: 100vh;
    position: relative;
  }

  .scanlines {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.15) 0px,
      rgba(0, 0, 0, 0.15) 1px,
      transparent 1px,
      transparent 2px
    );
  }

  .font-mono {
    font-family: 'JetBrains Mono', monospace;
  }
</style>
