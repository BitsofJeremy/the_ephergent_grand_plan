---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const posts = await getCollection('transmissions');
---
<BaseLayout title="Transmissions" description="In-character broadcasts from the Ephergent crew.">
  <section class="section-hero">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <h1 class="font-display font-black text-5xl md:text-6xl tracking-tight mb-4">TRANSMISSIONS</h1>
      <p class="text-text-secondary text-lg max-w-2xl">Weekly in-character broadcasts from the crew, written by Hermes agents.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-12">
    {posts.length > 0 ? (
      <div class="space-y-4 max-w-3xl">
        {posts.map(p => (
          <article class="card">
            <h3>{p.data.title ?? p.slug}</h3>
            {p.data.excerpt && <p class="text-text-secondary">{p.data.excerpt}</p>}
            <div class="flex gap-3 mt-4">
              <a href={`/transmissions/${p.slug}/`} class="btn-ghost">Read</a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h3>No transmissions yet</h3>
        <p>New broadcasts are coming. Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
