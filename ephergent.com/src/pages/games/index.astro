---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
const games = await getCollection('games');
---
<BaseLayout title="Games" description="Browser-playable games from the Ephergent universe.">
  <section class="section-hero">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <h1 class="font-display font-black text-5xl md:text-6xl tracking-tight mb-4">GAMES</h1>
      <p class="text-text-secondary text-lg max-w-2xl">Play browser and downloadable games from the Ephergent universe. Each game is a small, self-contained story.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-12">
    {games.length > 0 ? (
      <div class="content-grid">
        {games.map(g => (
          <article class="card">
            <h3>{g.data.title ?? g.slug}</h3>
            <p>{g.data.summary ?? g.data.description ?? 'A game from the Ephergent universe.'}</p>
            <div class="flex gap-3 mt-4">
              <a href={`/games/${g.slug}/play/`} class="btn-primary">Play</a>
              <a href={`/games/${g.slug}/about/`} class="btn-ghost">About</a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h3>Games coming soon</h3>
        <p>New games are in development. Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
