---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Tune the Dial" description="A browser-playable Godot game from the Ephergent universe.">
  <section class="section-hero">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <a href="/games/" class="text-text-secondary hover:text-accent-cyan text-sm mb-4 inline-block">← Back to Games</a>
      <h1 class="font-display font-black text-4xl md:text-5xl tracking-tight mt-4">Tune the Dial</h1>
      <p class="text-accent-cyan text-lg mt-2">Browser game · Godot 4</p>
    </div>
  </section>
  <section class="max-w-6xl mx-auto px-6 py-12">
    <div class="max-w-3xl">
      <p class="text-text-secondary text-lg mb-8">This game is being prepared. Check back soon.</p>
      <div class="flex gap-4">
        <a href="/games/" class="btn-ghost">All Games</a>
      </div>
    </div>
  </section>
</BaseLayout>
