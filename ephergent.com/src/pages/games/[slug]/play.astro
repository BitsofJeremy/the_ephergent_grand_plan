---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
export async function getStaticPaths() {
  const games = await getCollection('games');
  return games.map((g) => ({ params: { slug: g.slug }, props: { entry: g } }));
}
const { entry } = Astro.props;
---
<BaseLayout title={`Play ${entry.data.title ?? entry.slug}`} description={`Play ${entry.data.title ?? entry.slug}`}>
  <section class="max-w-6xl mx-auto px-6 py-12">
    <a href="/games/" class="text-text-secondary hover:text-accent-cyan text-sm mb-4 inline-block">← Back to Games</a>
    <h1 class="font-display font-black text-4xl md:text-5xl tracking-tight mt-4 mb-8">{entry.data.title ?? entry.slug}</h1>

    {entry.data.embed_path ? (
      <div class="w-full rounded-xl overflow-hidden border border-border-subtle" style="aspect-ratio: 16/9;">
        <iframe
          src={entry.data.embed_path}
          width="100%"
          height="100%"
          style="border: none;"
          allowfullscreen
          loading="lazy"
          title={`Play ${entry.data.title ?? entry.slug}`}
        ></iframe>
      </div>
    ) : (
      <div class="empty-state card">
        <h3>Game not yet available</h3>
        <p>This game is still being prepared. Check back soon.</p>
      </div>
    )}

    <div class="mt-6 flex gap-4 items-center text-sm text-text-secondary">
      {entry.data.size && <span>Size: {entry.data.size}</span>}
      {entry.data.engine && <span>Engine: {entry.data.engine}</span>}
    </div>

    <div class="mt-8 pt-8 border-t border-border-subtle flex gap-4">
      <a href={`/games/${entry.slug}/about/`} class="btn-ghost">About This Game</a>
    </div>
  </section>
</BaseLayout>
