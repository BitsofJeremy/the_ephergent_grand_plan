---
import BaseLayout from '../layouts/BaseLayout.astro';
const modules = import.meta.glob('./journal/*.md', { eager: true });
const Ep = modules['./journal/S01E01_the_day_the_dial_broke.md'];
---

<BaseLayout title="Ephergent — Tune the Dial" description={Ep?.frontmatter?.summary ?? 'Tune the dial, find your frequency.'}>
  <div class="hero-mesh min-h-screen flex items-center">
    <section class="max-w-4xl mx-auto p-8">
      <h1 class="text-6xl font-black tracking-tight mb-4" style="font-family: 'Space Grotesk', Inter, system-ui;">EPHERGENT</h1>
      <p class="text-lg text-text-secondary mb-6">Tune the dial. Discover Season 01 — Episode 01.</p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <article class="product-glow glow-cyan rounded-lg p-6 bg-bg-surface/60 border border-border-subtle">
          <h2 class="text-2xl font-semibold mb-2">{Ep?.frontmatter?.title ?? 'Episode 01'}</h2>
          <p class="text-sm text-text-secondary mb-4">{Ep?.frontmatter?.summary ?? 'A first transmission from Pixel Paradox.'}</p>
          <a href="/journal/S01E01_the_day_the_dial_broke/" class="inline-block px-4 py-2 rounded-md bg-accent-cyan text-bg-deep font-semibold">Read Episode 01</a>
        </article>

        <aside class="p-6 rounded-lg bg-bg-elevated/60 border border-border-subtle">
          <h3 class="font-semibold mb-2">Quick Links</h3>
          <ul class="space-y-2 text-sm">
            <li><a href="/games/" class="text-accent-cyan">Games</a></li>
            <li><a href="/crew/" class="text-accent-cyan">Crew</a></li>
            <li><a href="/atlas/" class="text-accent-cyan">Lore Atlas</a></li>
            <li><a href="/transmissions/" class="text-accent-cyan">Transmissions</a></li>
          </ul>
        </aside>
      </div>
    </section>
  </div>
</BaseLayout>
