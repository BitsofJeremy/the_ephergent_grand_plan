---
import BaseLayout from '../../layouts/BaseLayout.astro';
const modules = import.meta.glob('./*.md', { eager: true });
const episodes = Object.entries(modules)
  .map(([path, mod]) => ({ slug: path.replace('./', '').replace('.md', ''), data: mod.frontmatter }))
  .filter(e => e.data && e.data.season === 1)
  .sort((a, b) => (a.data.episode || 0) - (b.data.episode || 0));
---
<BaseLayout title="Journal" description="Ephergent Season 01 — episodic fiction and lore.">
  <section class="section-hero">
    <div class="max-w-6xl mx-auto px-6 py-16">
      <h1 class="font-display font-black text-5xl md:text-6xl tracking-tight mb-4">JOURNAL</h1>
      <p class="text-text-secondary text-lg max-w-2xl">Season 01 — episodic fiction and lore from the Ephergent universe.</p>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-6 py-12">
    {episodes.length > 0 ? (
      <div class="space-y-4 max-w-3xl">
        {episodes.map(ep => (
          <article class="card">
            <div class="flex items-start justify-between gap-4">
              <div>
                <span class="text-accent-cyan text-sm font-mono">{ep.slug.toUpperCase()}</span>
                <h3 class="font-display font-bold text-lg mt-1">{ep.data.title ?? ep.slug}</h3>
                {ep.data.summary && <p class="text-text-secondary text-sm mt-1">{ep.data.summary}</p>}
              </div>
              <a href={`/journal/${ep.slug}/`} class="btn-ghost shrink-0">Read</a>
            </div>
          </article>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <h3>No episodes yet</h3>
        <p>Season 01 is being prepared. Check back soon.</p>
      </div>
    )}
  </section>
</BaseLayout>
