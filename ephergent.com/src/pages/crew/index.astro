---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const crew = await getCollection('crew');

// Sort crew alphabetically
crew.sort((a, b) => (a.data.name || a.slug).localeCompare(b.data.name || b.slug));

// Pre-compute all derived fields to avoid complex template expressions
const crewCards = crew.map(c => ({
  slug: c.slug,
  name: c.data.name || c.slug,
  role: c.data.role || '',
  quote: c.data.quote || '',
  quoteText: c.data.quote ? c.data.quote.replace(/^["']|["']$/g, '') : '',
  pronouns: c.data.pronouns || '',
  color_accent: c.data.color_accent || '',
  games: Array.isArray(c.data.games) ? c.data.games.join(', ') : '',
  hasGames: Array.isArray(c.data.games) && c.data.games.length > 0,
  hasQuote: !!(c.data.quote),
  hasColor: !!(c.data.color_accent),
  hasPronouns: !!(c.data.pronouns),
}));
---
<BaseLayout title="Crew Manifest" description="Personnel files for the crew of The Ephergent.">
  <div class="terminal-container min-h-screen font-mono">
    <div class="scanlines" aria-hidden="true"></div>

    <main class="max-w-6xl mx-auto p-6 md:p-12">
      <header class="mb-12">
        <div class="label-accent text-xs mb-2">EPHERGENT STATION // PERSONNEL DIVISION</div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 label-green">CREW MANIFEST</h1>
        <p class="text-lg max-w-2xl label-secondary">
          {crewCards.length} crew members registered.
          The Ephergent crew -- nine people, a dog, a Keeper, and a legend.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {crewCards.map(c => (
          <article class="crew-card rounded-lg p-6" style="background: rgba(18, 18, 25, 0.3); border: 1px solid #2a2a3a;">
            {c.hasColor && (
              <div class="h-1 w-full rounded mb-4" style={`background-color: ${c.color_accent}`}></div>
            )}

            <div class="flex items-start justify-between mb-3">
              <h2 class="text-xl font-bold mb-2 label-primary">{c.name}</h2>
              {c.hasPronouns && (
                <span class="text-xs label-secondary">{c.pronouns}</span>
              )}
            </div>

            {c.role && (
              <p class="text-sm mb-3 label-cyan">{c.role}</p>
            )}

            {c.hasQuote && (
              <blockquote class="text-sm italic pl-3 my-3 label-secondary" style="border-left: 2px solid rgba(255, 176, 32, 0.5);">
                &quot;{c.quoteText}&quot;
              </blockquote>
            )}

            {c.hasGames && (
              <div class="flex flex-wrap gap-2 mt-4">
                <span class="text-xs label-accent">Games: {c.games}</span>
              </div>
            )}

            <a href={`/crew/${c.slug}/`} class="text-sm mt-4 inline-block transition-colors label-cyan">
              [VIEW FILE] -&gt;
            </a>
          </article>
        ))}
      </div>

      <footer class="mt-16 pt-8" style="border-top: 1px solid #2a2a3a;">
        <div class="flex flex-wrap gap-4 text-xs label-secondary">
          <span class="label-green">* PERSONNEL DATABASE ONLINE</span>
          <span>|</span>
          <span>REGISTERED CREW: {crewCards.length}</span>
          <span>|</span>
          <span>STATUS: ACTIVE</span>
        </div>
      </footer>
    </main>
  </div>
</BaseLayout>

<style>
  .terminal-container {
    background: #08080d;
    min-height: 100vh;
    position: relative;
  }

  .scanlines {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1000;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.15) 0px,
      rgba(0, 0, 0, 0.15) 1px,
      transparent 1px,
      transparent 2px
    );
  }

  .font-mono {
    font-family: 'JetBrains Mono', monospace;
  }

  .label-primary { color: #e8e8f0; }
  .label-secondary { color: #9090b0; }
  .label-accent { color: #ffb020; }
  .label-green { color: #00e676; }
  .label-cyan { color: #00d4ff; }
</style>
