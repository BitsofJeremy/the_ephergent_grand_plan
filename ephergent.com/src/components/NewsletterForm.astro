---
---
<div class="border border-accent-cyan/20 rounded-lg p-8 bg-bg-surface">
  <h3 class="font-display font-bold text-2xl text-text-primary mb-2">Get notified about new products.</h3>
  <p class="text-text-secondary mb-6">New product drops, limited editions, and build updates. No spam.</p>
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/BitsofJeremy"
    method="post"
    target="popupwindow"
    onsubmit="window.open('https://buttondown.com/BitsofJeremy', 'popupwindow')"
    class="flex flex-col sm:flex-row gap-3"
  >
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="flex-1 px-4 py-3 bg-bg-deep border border-border-subtle rounded text-text-primary placeholder-text-secondary focus:outline-none focus:border-accent-cyan focus:ring-1 focus:ring-accent-cyan transition-all duration-300 font-body"
    />
    <input type="hidden" value="1" name="embed" />
    <button
      type="submit"
      class="px-6 py-3 bg-accent-cyan text-bg-deep font-semibold rounded hover:bg-accent-cyan/90 hover:scale-105 active:scale-95 transition-all duration-300 whitespace-nowrap"
    >
      Subscribe →
    </button>
  </form>
  <p class="text-text-secondary text-xs mt-3">Powered by Buttondown. Unsubscribe anytime.</p>
</div>
