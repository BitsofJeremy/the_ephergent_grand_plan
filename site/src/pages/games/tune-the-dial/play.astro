---
// Play page — embedded Godot game
---

<html>
  <head>
    <title>Play Tune the Dial | ephergent.com</title>
    <style>
      body {
        background: #0a0a1a;
        margin: 0;
        padding: 0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
      }
      .game-container {
        width: 100%;
        max-width: 1000px;
        padding: 1rem;
      }
      iframe {
        width: 100%;
        height: 600px;
        border: 2px solid #0ff1ce33;
        border-radius: 0.5rem;
        background: #000;
      }
      .game-footer {
        width: 100%;
        max-width: 1000px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1rem;
        font-family: 'Share Tech Mono', monospace;
        color: #0ff1ce88;
        font-size: 0.9rem;
      }
      .back-link {
        color: #0ff1ce;
        text-decoration: none;
        border: 1px solid #0ff1ce66;
        border-radius: 1rem;
        padding: 0.3rem 1rem;
      }
      .back-link:hover {
        background: #0ff1ce;
        color: #0a0a1a;
      }
      .size-note {
        color: #0ff1ce44;
      }
    </style>
  </head>
  <body>
    <div class="game-container">
      <iframe src="/games/tune-the-dial/index.html" allowfullscreen></iframe>
    </div>
    <div class="game-footer">
      <a href="/games/tune-the-dial/" class="back-link">← Back to Game</a>
      <span class="size-note">11.2 MB · Godot 4 HTML5 · Free forever</span>
    </div>
  </body>
</html>
